"""
models.py — Pydantic models for MCP tool inputs and CM API outputs.

Two groups:
  - Input models:   validate arguments passed to each MCP tool.
  - Output models:  define the structure of each tool's response payload.
"""

from __future__ import annotations

from enum import Enum
from typing import Optional, Literal

from pydantic import BaseModel, Field, field_validator


# ─────────────────────────────────────────────────────────────────────────────
# ENUMERATIONS
# ─────────────────────────────────────────────────────────────────────────────

class AlertSeverity(str, Enum):
    CRITICAL = "CRITICAL"
    WARNING  = "WARNING"
    INFO     = "INFORMATIONAL"
    ALL      = "ALL"


class ServiceState(str, Enum):
    STARTED = "STARTED"
    STOPPED = "STOPPED"
    UNKNOWN = "UNKNOWN"


class HealthStatus(str, Enum):
    GOOD        = "GOOD"
    CONCERNING  = "CONCERNING"
    BAD         = "BAD"
    DISABLED    = "DISABLED"
    UNKNOWN     = "UNKNOWN"


# ─────────────────────────────────────────────────────────────────────────────
# INPUT MODELS  (one per MCP tool)
# ─────────────────────────────────────────────────────────────────────────────

class LogsInput(BaseModel):
    """Input for the get_service_logs tool."""

    cluster_name:   str                                                    = Field(..., description="DataHub cluster name")
    service_name:   str                                                    = Field(..., description="CM service name (e.g. YARN, HDFS, SOLR)")
    start_time:     str                                                    = Field(..., description="ISO 8601 start time (e.g. 2024-11-01T00:00:00Z)")
    end_time:       Optional[str]                                          = Field(None, description="ISO 8601 end time. Defaults to now")
    host_filter:    Optional[str]                                          = Field(None, description="Filter by hostname (substring match)")
    role_filter:    Optional[str]                                          = Field(None, description="Filter by role type (e.g. NODEMANAGER)")
    level_filter:   Optional[Literal["FATAL","ERROR","WARN","INFO","DEBUG","TRACE"]] = Field(None, description="Minimum log level")
    keyword_filter: Optional[str]                                          = Field(None, description="Keyword to search in log messages")
    max_lines:      Optional[int]                                          = Field(1000, ge=1, le=5000, description="Maximum number of log lines to return")

    @field_validator("start_time", "end_time", mode="before")
    @classmethod
    def _validate_iso8601(cls, value: str) -> str:
        from datetime import datetime
        if not value:
            return value
        try:
            datetime.fromisoformat(value.replace("Z", "+00:00"))
        except ValueError:
            raise ValueError(
                f"Invalid datetime format: {value}. Use ISO 8601 (e.g. 2024-11-01T00:00:00Z)"
            )
        return value


class AlertsInput(BaseModel):
    """Input for the get_alerts tool."""

    cluster_name:   Optional[str]  = Field(None, description="Cluster name. Omit to query all clusters")
    severity:       AlertSeverity  = Field(AlertSeverity.ALL, description="Minimum severity filter")
    start_time:     Optional[str]  = Field(None, description="ISO 8601 start time")
    end_time:       Optional[str]  = Field(None, description="ISO 8601 end time. Defaults to now")
    service_filter: Optional[str]  = Field(None, description="Filter by service name")
    max_results:    int            = Field(100, ge=1, le=1000)


class MetricsInput(BaseModel):
    """Input for the get_service_metrics tool."""

    cluster_name:  str        = Field(..., description="DataHub cluster name")
    service_name:  str        = Field(..., description="CM service name")
    metric_names:  list[str]  = Field(..., description="List of CM metric names (e.g. ['cpu_percent','jvm_heap_used'])")
    start_time:    str        = Field(..., description="ISO 8601 start time")
    end_time:      Optional[str] = Field(None, description="ISO 8601 end time. Defaults to now")
    roll_up:       Optional[Literal["RAW","TEN_MINUTELY","HOURLY","DAILY"]] = Field(
        "TEN_MINUTELY", description="Time-series granularity"
    )


class ConfigReadInput(BaseModel):
    """Input for the get_config tool."""

    cluster_name:       str           = Field(..., description="DataHub cluster name")
    service_name:       str           = Field(..., description="CM service name")
    role_config_group:  Optional[str] = Field(
        None, description="Role config group (e.g. yarn-NODEMANAGER-BASE). Omit for service-level config"
    )
    view: Literal["summary", "full"]  = Field(
        "full", description="'summary'=overrides only, 'full'=all parameters including defaults"
    )


class ConfigUpdateInput(BaseModel):
    """Input for the update_config tool."""

    cluster_name:       str           = Field(..., description="DataHub cluster name")
    service_name:       str           = Field(..., description="CM service name")
    config_key:         str           = Field(..., description="Exact parameter key (e.g. yarn_nodemanager_resource_memory_mb)")
    config_value:       str           = Field(..., description="New value (always as string)")
    role_config_group:  Optional[str] = Field(None, description="Target role config group. Omit for service-level")
    message:            Optional[str] = Field(None, description="Audit message for the change")


class ServiceCommandInput(BaseModel):
    """Input for the run_service_command tool."""

    cluster_name:      str = Field(..., description="DataHub cluster name")
    service_name:      str = Field(..., description="CM service name")
    command:           Literal["start","stop","restart","rollingRestart","decommission"] = Field(
        ..., description="Command to execute on the service"
    )
    slave_batch_size:  Optional[int] = Field(None, description="rollingRestart: hosts per batch")
    slave_fail_count:  Optional[int] = Field(None, description="rollingRestart: maximum tolerated failures")


class CommandStatusInput(BaseModel):
    """Input for the get_command_status tool."""

    command_id:   int = Field(..., description="CM command ID returned by run_service_command")
    cluster_name: str = Field(..., description="Cluster the command was issued against")


class HostStatusInput(BaseModel):
    """Input for the get_host_status tool."""

    cluster_name:  Optional[str] = Field(None, description="Filter by cluster. Omit for all hosts")
    host_filter:   Optional[str] = Field(None, description="Filter by hostname (substring match)")
    include_roles: bool          = Field(True, description="Include active role list per host")


class AuditInput(BaseModel):
    """Input for the get_audit_events tool."""

    cluster_name:     Optional[str]  = Field(None, description="Cluster name. Omit for all clusters")
    start_time:       str            = Field(..., description="ISO 8601 start time")
    end_time:         Optional[str]  = Field(None, description="ISO 8601 end time. Defaults to now")
    service_filter:   Optional[str]  = Field(None, description="Filter by service (e.g. HDFS, YARN)")
    user_filter:      Optional[str]  = Field(None, description="Filter by CM username")
    operation_filter: Optional[str]  = Field(None, description="Filter by operation type (e.g. LOGIN, CONFIG_CHANGE)")
    allowed_filter:   Optional[bool] = Field(None, description="True=allowed only, False=denied only, None=both")
    max_results:      int            = Field(200, ge=1, le=2000)


class ListDataHubsInput(BaseModel):
    """Input for the list_datahubs tool."""

    environment_name: Optional[str] = Field(None, description="Filter by CDP environment name. Omit for all")
    status_filter:    Optional[Literal["AVAILABLE","STOPPED","FAILED","ALL"]] = Field(
        "ALL", description="Filter by DataHub status"
    )


# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT MODELS  (structure of each tool's response)
# ─────────────────────────────────────────────────────────────────────────────

class LogEntry(BaseModel):
    timestamp: str
    level:     str
    host:      str
    role:      str
    message:   str
    log_class: Optional[str] = None


class LogsResult(BaseModel):
    cluster:     str
    service:     str
    total_lines: int
    truncated:   bool
    start_time:  str
    end_time:    str
    entries:     list[LogEntry]


class Alert(BaseModel):
    timestamp: str
    severity:  str
    service:   Optional[str]
    host:      Optional[str]
    cluster:   str
    content:   str
    category:  Optional[str] = None


class AlertsResult(BaseModel):
    total:  int
    alerts: list[Alert]


class MetricPoint(BaseModel):
    timestamp: str
    value:     Optional[float]


class MetricSeries(BaseModel):
    metric_name: str
    entity_name: str
    unit:        Optional[str]
    points:      list[MetricPoint]


class MetricsResult(BaseModel):
    cluster: str
    service: str
    series:  list[MetricSeries]


class ConfigParam(BaseModel):
    name:               str
    value:              Optional[str]
    default_value:      Optional[str]
    required:           bool
    sensitive:          bool
    description:        Optional[str]
    validation_state:   Optional[str] = None
    validation_message: Optional[str] = None


class ConfigResult(BaseModel):
    cluster:           str
    service:           str
    role_config_group: Optional[str]
    params:            list[ConfigParam]


class ConfigUpdateResult(BaseModel):
    cluster:    str
    service:    str
    config_key: str
    old_value:  Optional[str]
    new_value:  str
    success:    bool
    message:    str


class CommandResult(BaseModel):
    command_id:     int
    name:           str
    cluster:        str
    service:        str
    success:        Optional[bool]
    active:         bool
    start_time:     Optional[str]
    end_time:       Optional[str]
    result_message: Optional[str]


class RoleInfo(BaseModel):
    role_name:     str
    role_type:     str
    service_name:  str
    health_status: str


class HostInfo(BaseModel):
    hostname:         str
    ip_address:       str
    cluster:          Optional[str]
    health_status:    str
    commission_state: str
    maintenance_mode: bool
    num_cores:        int
    total_ram_gb:     float
    roles:            list[RoleInfo]


class HostStatusResult(BaseModel):
    total_hosts: int
    hosts:       list[HostInfo]


class AuditEntry(BaseModel):
    timestamp:  str
    service:    str
    user:       str
    command:    str
    resource:   Optional[str]
    operation:  str
    allowed:    bool
    ip_address: Optional[str]
    cluster:    str


class AuditResult(BaseModel):
    total:   int
    entries: list[AuditEntry]


class DataHubInfo(BaseModel):
    name:           str
    environment:    str
    status:         str
    cluster_type:   Optional[str]
    cm_host:        str
    services:       list[str]
    nodes_count:    int
    cloud_provider: Optional[str]
    region:         Optional[str]


class DataHubsResult(BaseModel):
    total:    int
    datahubs: list[DataHubInfo]