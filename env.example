# ─────────────────────────────────────────────────────────────────────────────
# Cloudera Manager MCP Server — Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control — add it to .gitignore.
#
# Variable groups:
#   MCP_*     → MCP server behaviour (limits, retry, logging)
#   IMPALA_*  → SQL backend for the CM registry Iceberg table
#               (Impala or HiveServer2 — see IMPALA_BACKEND below)
#
# CM host/credentials are NOT stored here.
# They live in the Iceberg table:  <IMPALA_DATABASE>.<IMPALA_TABLE>
# Manage them at runtime via the registry_add / registry_update_field tools,
# or insert rows directly using docs/registry_table.sql.
# ─────────────────────────────────────────────────────────────────────────────


# ── MCP Server ────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
MCP_LOG_LEVEL=INFO

# Maximum number of log lines returned by get_service_logs
MCP_MAX_LOG_LINES=5000

# Maximum time range (hours) allowed for a single get_service_logs request
MCP_MAX_LOG_RANGE_HOURS=48

# Number of HTTP retry attempts on CM API failures before giving up
MCP_MAX_RETRIES=3

# Base wait time (seconds) between retries — actual wait grows exponentially
MCP_RETRY_WAIT_SECONDS=2.0

# Maximum number of concurrent HTTP requests towards a single CM instance
MCP_MAX_CONCURRENT_REQUESTS=10

# Rate limit: maximum CM API requests per minute per instance
MCP_REQUESTS_PER_MINUTE=60

# Default number of data points returned by get_service_metrics
MCP_DEFAULT_METRIC_POINTS=100


# ── SQL Backend (CM registry source) ─────────────────────────────────────────

# Backend engine: impala (port 21050) or hiveserver2 (port 10000)
IMPALA_BACKEND=impala

# Iceberg database and table
IMPALA_DATABASE=cdp_registry
IMPALA_TABLE=cloudera_managers

# ── Direct connection (IMPALA_USE_KNOX=false) ─────────────────────────────────

# Hostname or IP of the backend server (impalad or HiveServer2)
# Ignored when IMPALA_USE_KNOX=true
IMPALA_HOST=impala-coordinator.example.com

# Port — leave commented to use the backend default (21050 / 10000)
# IMPALA_PORT=21050

# Authentication: PLAIN | LDAP | GSSAPI
IMPALA_AUTH_MECHANISM=LDAP
IMPALA_USERNAME=svc-mcp-agent
IMPALA_PASSWORD=changeme

# Kerberos service name — only for GSSAPI; defaults to 'impala' or 'hive'
# IMPALA_KERBEROS_SERVICE_NAME=impala

# TLS for direct connections
IMPALA_USE_SSL=true
# IMPALA_CA_CERT=/etc/ssl/certs/cdp-ca-bundle.pem

# ── CDP Public Cloud load balancer / Knox (IMPALA_USE_KNOX=true) ─────────────
#
# When Knox is enabled:
#   - host / port / auth_mechanism above are IGNORED
#   - the connection goes to the CDP load balancer via HTTPS + HTTP transport
#   - credentials are sent as PLAIN over the HTTPS-secured channel
#   - the HTTP path follows the CDP Public Cloud convention:
#       Impala:      <cluster_name>/cdp-proxy-api/impala
#       HiveServer2: <cluster_name>/cdp-proxy-api/hive
#
# Reference JDBC strings (CDP Public Cloud):
#   Impala:
#     jdbc:impala://<lb_host>:<lb_port>/;ssl=1;transportMode=http;
#     httpPath=<cluster_name>/cdp-proxy-api/impala;AuthMech=3
#   HiveServer2:
#     jdbc:hive2://<lb_host>:<lb_port>/;ssl=true;transportMode=http;
#     httpPath=<cluster_name>/cdp-proxy-api/hive
#
IMPALA_USE_KNOX=false

# CDP load balancer hostname — required when IMPALA_USE_KNOX=true
# From CDP console: Environment → Summary → Load Balancer URL
# IMPALA_LB_HOST=lb.prod-eu.cdp.example.com

# CDP load balancer port (default 443 in CDP Public Cloud)
# IMPALA_LB_PORT=443

# CDP DataHub cluster name — required when IMPALA_USE_KNOX=true
# Used to build the httpPath: <cluster_name>/cdp-proxy-api/<service>
# IMPALA_CLUSTER_NAME=datahub-prod-eu

# Knox uses IMPALA_USERNAME and IMPALA_PASSWORD (already set above)
# Knox TLS uses IMPALA_CA_CERT (already set above)

# ── Behaviour ─────────────────────────────────────────────────────────────────

# Query timeout in seconds
IMPALA_TIMEOUT_SECONDS=30

# Number of persistent connections in the pool
IMPALA_POOL_SIZE=3

# Cache refresh interval in seconds (0 = never; use registry_reload tool instead)
IMPALA_REFRESH_INTERVAL_SECS=300
